PROXMOX_URL=https://proxmox.example
PROXMOX_USERNAME=root
PROXMOX_PASSWORD=
PROXMOX_REALM=pam

# Preferred for CI and publishing workflows:
# PROXMOX_API_TOKEN_ID=root@pam!alchemy
# PROXMOX_API_TOKEN_SECRET=

PROXMOX_E2E_NODE=proxmox
PROXMOX_E2E_VM_STORAGE=vault-vm
PROXMOX_E2E_LXC_STORAGE=vault-lxc
PROXMOX_E2E_LXC_TEMPLATE=local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst
# Optional. Tests generate an ephemeral password when omitted.
# PROXMOX_E2E_LXC_PASSWORD=
